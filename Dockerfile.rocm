# AMD ROCm GPU image (passes /dev/kfd and /dev/dri from the host).
FROM rocm/pytorch:rocm7.2.2_ubuntu22.04_py3.10_pytorch_release_2.7.1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY video-watcher ./
RUN chmod +x video-watcher \
    && pip install -q --upgrade pip \
    && pip install -q openai-whisper \
    && chmod -R a+rX /app

ENV XDG_CACHE_HOME=/cache
ENTRYPOINT ["./video-watcher"]
