# AMD ROCm GPU image (passes /dev/kfd and /dev/dri from the host).
FROM rocm/pytorch:rocm7.2.2_ubuntu22.04_py3.10_pytorch_release_2.7.1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg git cmake build-essential libportaudio2 \
    && rm -rf /var/lib/apt/lists/*

# ROCm llama-cli for --summary (--gpu passes -ngl 999). Override at build: --build-arg GPU_TARGETS=gfx1100
ARG GPU_TARGETS=gfx1030
RUN git clone --depth 1 https://github.com/ggml-org/llama.cpp /tmp/llama.cpp \
    && HIPCXX="$(hipconfig -l)/clang++" cmake -S /tmp/llama.cpp -B /tmp/llama-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_SHARED_LIBS=ON \
        -DGGML_HIP=ON \
        -DGPU_TARGETS="${GPU_TARGETS}" \
        -DGGML_NATIVE=OFF \
    && cmake --build /tmp/llama-build -j"$(nproc)" --target llama-cli \
    && install -d /opt/llama \
    && cp /tmp/llama-build/bin/llama-cli /opt/llama/ \
    && cp /tmp/llama-build/bin/*.so* /opt/llama/ \
    && rm -rf /tmp/llama.cpp /tmp/llama-build

WORKDIR /app
COPY video-watcher ./
COPY vw ./vw/
RUN python -m pip install -q --upgrade pip \
    && python -m pip install -q openai-whisper tqdm sounddevice yt-dlp youtube-transcript-api \
    && python -c "import sounddevice, whisper" \
    && chmod -R a+rX /app

ENV PYTHONPATH=/app
ENV VIDEO_WATCHER_CACHE=/cache
ENV XDG_CACHE_HOME=/cache
ENV PATH=/opt/llama:${PATH}
ENV LD_LIBRARY_PATH=/opt/llama:${LD_LIBRARY_PATH:-}
ENV VIDEO_WATCHER_LLAMA_CLI=/opt/llama/llama-cli
ENTRYPOINT ["python", "-m", "vw"]
