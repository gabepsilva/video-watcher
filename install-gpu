#!/usr/bin/env bash
# ROCm (AMD GPU) PyTorch + Whisper for video-watcher.
# Ubuntu 24.04 + Python 3.12 — see README.md for other versions.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${SCRIPT_DIR}/.venv"
OLD_VENV="${SCRIPT_DIR}/.caption-venv"
CACHE_DIR="${SCRIPT_DIR}/.cache/rocm-wheels"
ROCM_REL="6.4.2"
PY_TAG="cp312-cp312-linux_x86_64"
FORCE=false

WHEEL_BASE="https://repo.radeon.com/rocm/manylinux/rocm-rel-${ROCM_REL}"
WHEELS=(
  "torch-2.6.0%2Brocm6.4.2.git76481f7c-${PY_TAG}.whl"
  "torchvision-0.21.0%2Brocm6.4.2.git4040d51f-${PY_TAG}.whl"
  "pytorch_triton_rocm-3.2.0%2Brocm6.4.2.git7e948ebf-${PY_TAG}.whl"
  "torchaudio-2.6.0%2Brocm6.4.2.gitd8831425-${PY_TAG}.whl"
)

log() { printf '%s\n' "$*" >&2; }

usage() {
  cat <<'EOF'
Usage: install-gpu [--force]

Installs ROCm PyTorch + openai-whisper into .venv.
Skips if already configured (use --force to reinstall).
EOF
}

require() {
  command -v "$1" >/dev/null 2>&1 || { log "Missing required command: $1"; exit 1; }
}

migrate_venv() {
  if [[ -d "$OLD_VENV" && ! -d "$VENV_DIR" ]]; then
    log "Migrating .caption-venv → .venv ..."
    mv "$OLD_VENV" "$VENV_DIR"
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -f|--force) FORCE=true; shift ;;
    *) log "Unknown option: $1"; usage; exit 1 ;;
  esac
done

require python3
require wget
require rocm-smi

migrate_venv

mkdir -p "${CACHE_DIR}"

if [[ -d "${VENV_DIR}" ]]; then
  if [[ -f "${VENV_DIR}/bin/pip" ]] && ! "${VENV_DIR}/bin/pip" --version >/dev/null 2>&1; then
    log "Recreating venv (broken after move)..."
    rm -rf "${VENV_DIR}"
  fi
fi
if [[ ! -d "${VENV_DIR}" ]]; then
  log "Creating virtualenv..."
  python3 -m venv "${VENV_DIR}"
fi

PY="${VENV_DIR}/bin/python"
pip() { "${PY}" -m pip "$@"; }

rocm_ready() {
  "${PY}" -c "
import importlib.util
import torch
if not torch.cuda.is_available():
    raise SystemExit(1)
if 'rocm' not in torch.__version__.lower():
    raise SystemExit(1)
if importlib.util.find_spec('whisper') is None:
    raise SystemExit(1)
" 2>/dev/null
}

if [[ "$FORCE" != true ]] && rocm_ready; then
  "${PY}" -c "
import torch
print('Already configured.')
print('GPU:', torch.cuda.get_device_name(0))
print('PyTorch:', torch.__version__)
"
  log "Use --force to reinstall ROCm PyTorch."
  exit 0
fi

log "Installing numpy (ROCm wheel compatibility)..."
pip install -q --upgrade pip
pip install -q "numpy==1.26.4"

log "Downloading ROCm PyTorch wheels..."
for w in "${WHEELS[@]}"; do
  dest="${CACHE_DIR}/$(printf '%s' "$w" | sed 's/%2B/+/g')"
  if [[ ! -f "$dest" ]]; then
    wget -q -O "$dest" "${WHEEL_BASE}/${w}"
  fi
done

log "Removing non-ROCm torch packages..."
pip uninstall -y torch torchvision torchaudio pytorch-triton-rocm 2>/dev/null || true

log "Installing ROCm PyTorch..."
pip install -q "${CACHE_DIR}"/*.whl

log "Installing triton (whisper dependency)..."
pip install -q "triton>=2"

log "Installing openai-whisper..."
pip install -q openai-whisper sounddevice

log "Verifying GPU..."
if ! "${PY}" -c "
import torch
assert torch.cuda.is_available()
print('GPU:', torch.cuda.get_device_name(0))
print('PyTorch:', torch.__version__)
"; then
  log ""
  log "GPU not visible. For RX 6000 (Navi 21), try:"
  log "  export HSA_OVERRIDE_GFX_VERSION=10.3.0"
  log "  ${SCRIPT_DIR}/install-gpu --force"
  exit 1
fi

log ""
log "ROCm ready. Run:"
log "  ${SCRIPT_DIR}/video-watcher --gpu -m small Downloads/your-video.mp4"
