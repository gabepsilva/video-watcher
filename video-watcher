#!/usr/bin/env bash
# video-watcher: thin launcher for the vw Python package.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${SCRIPT_DIR}/.venv"
export PYTHONPATH="${SCRIPT_DIR}${PYTHONPATH:+:${PYTHONPATH}}"

resolve_python() {
  if [[ -n "${VIDEO_WATCHER_PYTHON:-}" ]]; then
    printf '%s' "${VIDEO_WATCHER_PYTHON}"
  elif [[ -x "${VENV_DIR}/bin/python" ]]; then
    printf '%s' "${VENV_DIR}/bin/python"
  elif command -v python3 >/dev/null 2>&1; then
    command -v python3
  else
    return 1
  fi
}

if ! PY="$(resolve_python)"; then
  printf '%s\n' "No Python found. Run: ${SCRIPT_DIR}/install-local" >&2
  printf '%s\n' "Or use Docker: ${SCRIPT_DIR}/video-watcher-docker" >&2
  exit 1
fi

printf '%s\n' "video-watcher: checking environment …" >&2

if ! "${PY}" -c "import whisper" >/dev/null 2>&1; then
  printf '%s\n' "Whisper not installed. Run: ${SCRIPT_DIR}/install-local" >&2
  exit 1
fi

export PYTHONUNBUFFERED=1
exec "${PY}" -m vw "$@"
