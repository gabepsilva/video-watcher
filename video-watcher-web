#!/usr/bin/env bash
# Deprecated: web console runs only via Docker Compose.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

printf '%s\n' "video-watcher-web is deprecated." >&2
printf '%s\n' "Start the console with Docker Compose from the repo root:" >&2
printf '%s\n' "  cd ${SCRIPT_DIR} && docker compose up --build" >&2
printf '%s\n' "Then open http://127.0.0.1:8080 (UI; API on port 8765)." >&2

cd "${SCRIPT_DIR}"
exec docker compose up --build "$@"
