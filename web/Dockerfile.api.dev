# Dev API: ffmpeg + Python only. Repo, .venv, jobs, and cache are bind-mounted at runtime.
FROM python:3.12-slim-bookworm

RUN apt-get update \
  && apt-get install -y --no-install-recommends ffmpeg \
  && rm -rf /var/lib/apt/lists/*

COPY web/scripts/docker-dev-api-entrypoint.sh /usr/local/bin/docker-dev-api-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-dev-api-entrypoint.sh

WORKDIR /repo
EXPOSE 8765
ENTRYPOINT ["/usr/local/bin/docker-dev-api-entrypoint.sh"]
