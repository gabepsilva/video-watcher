# Dev UI: npm deps in image + entrypoint syncs lockfile into the node_modules volume.
FROM node:22-bookworm-slim

WORKDIR /app
COPY web/ui/package.json web/ui/package-lock.json ./
RUN npm ci

COPY web/scripts/docker-dev-ui-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 5173
ENTRYPOINT ["/entrypoint.sh"]
